{
  "name": "@pilotrun/cli",
  "version": "0.0.1",
  "description": "Terminal-first, provider-neutral coding agent CLI.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "bin": {
    "pilot": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "predeploy": "pnpm build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@earendil-works/pi-tui": "catalog:",
    "@pilotrun/agent-runtime": "workspace:*",
    "@pilotrun/core": "workspace:*",
    "@pilotrun/persistence-sqlite": "workspace:*",
    "@pilotrun/provider-openai-compatible": "workspace:*",
    "@pilotrun/testkit": "workspace:*",
    "@pilotrun/tools-builtin": "workspace:*",
    "zod": "catalog:"
  }
}
